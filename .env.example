# VPS stack defaults for docker-compose.vps.yml
# Copy this file to .env and change the secrets before deploying.

# Database
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=canary
MARIADB_USER=canary
MARIADB_PASSWORD=change-me-db

# Public endpoints / bindings
TIBIAOT_WEB_PORT=8080
MYAAC_HTTP_PORT=8089
LOGIN_HTTP_PORT=8088
LOGIN_GRPC_PORT=50051
OT_SERVER_LOGIN_PORT=7171
OT_SERVER_GAME_PORT=7172
OT_SERVER_STATUS_PORT=7171

# External IP or hostname advertised by the server/login service
OT_SERVER_IP=0.0.0.0
LOGIN_IP=0.0.0.0
TIBIAOT_ACCOUNT_BASE_URL=http://93.188.166.199:8089
TIBIAOT_SITE_BASE_URL=http://93.188.166.199:8089
TIBIAOT_API_BASE_URL=http://93.188.166.199:8088
TIBIAOT_WEB_BASE_URL=http://93.188.166.199:8090

# Canary game server
OT_SERVER_TEST_ACCOUNTS=false
OT_SERVER_DATA=data-otservbr-global
OT_SERVER_MAP=https://github.com/opentibiabr/canary/releases/download/v3.6.0/otservbr.otbm

# Login server
ENV_LOG_LEVEL=info
RATE_LIMITER_BURST=10
RATE_LIMITER_RATE=1
